# 이 파일을 복사해 .env 로 쓰세요. .env 는 Git에 올리지 마세요.
# cp .env.example .env

# CORS — 쉼표로 여러 Origin (Render/Vercel 배포 시 프론트 도메인)
# ALLOWED_ORIGINS=https://2026-01-chatbot.vercel.app

# Groq (선택)
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Ollama 로컬 (GROQ_API_KEY 없을 때)
# OLLAMA_HOST=http://127.0.0.1:11434
# OLLAMA_MODEL=llama3:latest

# ChromaDB — 아래 둘 중 하나만 쓰면 됨
# (1) URL 한 줄 (배포·Docker 네트워크에서 다른 호스트명 사용 시 권장)
# CHROMA_URL=http://localhost:8000
# CHROMA_URL=http://chromadb:8000
#
# (2) 호스트/포트 분리
# CHROMA_HOST=localhost
# CHROMA_PORT=8000
# CHROMA_SSL=false
#
# Chroma Cloud 등 토큰 필요 시
# CHROMA_API_TOKEN=

# PORT=3001
